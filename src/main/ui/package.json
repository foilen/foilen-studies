{
  "name": "ui",
  "version": "0.1.0",
  "private": true,
  "devDependencies": {
    "@jagannathbhat/cra-build-watch": "1.0.1"
  },
  "dependencies": {
    "@popperjs/core": "2.11.8",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "axios": "1.15.2",
    "bootstrap": "5.3.8",
    "bootstrap-icons": "1.13.1",
    "jquery": "4.0.0",
    "lodash": "4.18.1",
    "luxon": "3.7.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "7.14.2",
    "react-scripts": "5.0.1",
    "react-toastify": "11.1.0",
    "web-vitals": "5.2.0"
  },
  "scripts": {
    "start": "node node_modules/react-scripts/bin/react-scripts start",
    "watch": "cra-build-watch --build-path ../../../build/resources/main/static",
    "build": "node node_modules/react-scripts/bin/react-scripts build",
    "test": "node node_modules/react-scripts/bin/react-scripts test",
    "test:ci": "node node_modules/react-scripts/bin/react-scripts test --watchAll=false --passWithNoTests",
    "eject": "node node_modules/react-scripts/bin/react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
